# Firefly Services (required)
FIREFLY_SERVICES_CLIENT_ID=your_client_id_here
FIREFLY_SERVICES_CLIENT_SECRET=your_client_secret_here

# Optional: Firefly Custom Model asset ID for brand style
# CUSTOM_MODEL_ID=

# Local output (default: ./output)
OUTPUT_PATH=./output

# Server port for local UI/API (default: 3000)
PORT=3000

# Sneaker-on-foot pipeline (scripts/sneakerOnFootPipeline.js)
# PERSON_PHOTO_URL=https://...   # person with neutral shoe/sock
# MASK_IMAGE_URL=https://...     # mask PNG (white = shoe region to fill)
# SNEAKER_PNG_URL=https://...    # 3D sneaker render, transparent PNG
# FILL_PROMPT=empty floor, same lighting
# OUT_DIR=./output/sneaker-on-foot

# Optional: Photoshop API placement (Sneaker on foot tab – "Use Photoshop API for placement")
# Requires Azure Blob Storage; see docs/PHOTOSHOP_API_PLACE_LAYER.md
# AZURE_STORAGE_ACCOUNT_NAME=your-storage-account
# AZURE_STORAGE_ACCOUNT_KEY=your-account-key
# AZURE_STORAGE_CONTAINER=your-container-name
